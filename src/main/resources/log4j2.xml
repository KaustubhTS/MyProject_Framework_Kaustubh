<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN">

	<Appenders>

		<!-- Console Logs -->
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout
				pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] [%X{testName}] %-5level %c - %msg%n" />
				
		</Console>

		<!-- File Logs -->
		<File name="FileLogger"
			fileName="logs/${ctx:testName}.log"
			append="false">
			<PatternLayout>
				<Pattern>%d [%t] %-5level %c - %msg%n</Pattern>
			</PatternLayout>
		</File>

	</Appenders>

	<Loggers>

		<!-- Framework Logs -->
		<Root level="info">
			<AppenderRef ref="Console" />
			<AppenderRef ref="FileLogger" />
		</Root>

	</Loggers>

</Configuration>

